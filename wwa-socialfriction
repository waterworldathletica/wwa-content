  <div class="shot-header" onclick="toggle(this.parentElement)">
    <div class="cb"><svg class="check-icon" viewBox="0 0 13 13"><polyline points="2,6.5 5.5,10 11,3"/></svg></div>
    <div class="shot-body">
      <div class="shot-num">Clip 7</div>
      <div class="shot-title">Deep in the work — absorbed, unreachable</div>
      <div class="shot-detail">Music session, late night studio or production moment. Someone so locked in the outside world doesn't exist. The obsession is visible.</div>
