  <div class="complete-title">Completion</div>
  <div class="complete-row" data-id="c1" onclick="toggleComplete(this)">
    <div class="cb"><svg class="check-icon" viewBox="0 0 13 13"><polyline points="2,6.5 5.5,10 11,3"/></svg></div>
    <div class="complete-label">Archive clips pulled</div>
  </div>
  <div class="complete-row" data-id="c2" onclick="toggleComplete(this)">
