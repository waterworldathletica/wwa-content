    <div class="complete-label">Edit complete</div>
  </div>
  <div class="complete-row" data-id="c4" onclick="toggleComplete(this)">
    <div class="cb"><svg class="check-icon" viewBox="0 0 13 13"><polyline points="2,6.5 5.5,10 11,3"/></svg></div>
    <div class="complete-label">Posted</div>
  </div>
  <div class="date-label">COMPLETION DATE</div>
  <input type="date" class="date-input" id="completion-date" onchange="saveDate(this.value)">
</div>

<button class="reset-btn" onclick="resetAll()">Reset checklist</button>

<script>
const KEY = 'wwa_friction_v1';
function getState() { try { return JSON.parse(localStorage.getItem(KEY)) || {}; } catch(e) { return {}; } }
function setState(s) { try { localStorage.setItem(KEY, JSON.stringify(s)); } catch(e) {} }
function updateProgress() {
  const shots = document.querySelectorAll('.shot');
  const done = document.querySelectorAll('.shot.done').length;
  document.getElementById('prog-fill').style.width = Math.round((done / shots.length) * 100) + '%';
  document.getElementById('prog-text').textContent = done + ' / ' + shots.length;
}
function toggle(el) {
  el.classList.toggle('done');
  const s = getState(); s[el.dataset.id] = el.classList.contains('done'); setState(s);
  updateProgress();
}
function toggleComplete(el) {
  el.classList.toggle('done');
  const s = getState(); s[el.dataset.id] = el.classList.contains('done'); setState(s);
}
function saveDate(val) { const s = getState(); s.completion_date = val; setState(s); }
function resetAll() {
  document.querySelectorAll('.shot.done, .complete-row.done').forEach(el => el.classList.remove('done'));
  document.getElementById('completion-date').value = '';
  setState({}); updateProgress();
}
(function() {
  const s = getState();
  document.querySelectorAll('.shot, .complete-row').forEach(el => { if (s[el.dataset.id]) el.classList.add('done'); });
  if (s.completion_date) document.getElementById('completion-date').value = s.completion_date;
  updateProgress();
})();
</script>
